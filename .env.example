# Web
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# API
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Primary image provider: OpenAI-compatible Autocode API
IMAGE_PROVIDER=autocode
AUTOCODE_API_KEY=
AUTOCODE_BASE_URL=https://api.autocode.space
AUTOCODE_IMAGE_MODEL=gpt-image-2
AUTOCODE_IMAGE_SIZE=1728x2304

# Optional fallback image provider: Replicate (disabled by default)
REPLICATE_FALLBACK_ENABLED=false
REPLICATE_API_TOKEN=
REPLICATE_IMAGE_MODEL=
REPLICATE_IMAGE_WIDTH=1728
REPLICATE_IMAGE_HEIGHT=2304
REPLICATE_SUPPORTS_IMAGE_INPUT=true
